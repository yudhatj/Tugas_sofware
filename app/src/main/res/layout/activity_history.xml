<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical">

    <!-- CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- HEADER -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/chevron_left"
                    app:tint="#1E255E"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:text="Riwayat Absensi"
                    android:textColor="#1E255E"
                    android:textSize="20sp"
                    android:textStyle="bold"/>

            </RelativeLayout>

            <!-- FILTER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_edittext"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="18dp"
                android:paddingEnd="18dp">

                <TextView
                    android:id="@+id/tvBulan"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text=""
                    android:textColor="#1E255E"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/chevron_down"
                    app:tint="#7A7A7A"/>

            </LinearLayout>

            <!-- SUMMARY -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:columnCount="2">

                <!-- HADIR -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_summary"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/hadir"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Hadir"
                        android:textColor="#7A7A7A"
                        android:textSize="14sp"/>

                    <TextView
                        android:id="@+id/tvHadir"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="0 Hari"
                        android:textColor="#1E255E"
                        android:textSize="22sp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <!-- PULANG -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_summary"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/log"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Pulang"
                        android:textColor="#7A7A7A"
                        android:textSize="14sp"/>

                    <TextView
                        android:id="@+id/tvPulang"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="0 Kali"
                        android:textColor="#FF5722"
                        android:textSize="22sp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <!-- IZIN -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_summary"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/izin"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Izin"
                        android:textColor="#7A7A7A"
                        android:textSize="14sp"/>

                    <TextView
                        android:id="@+id/tvIzin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="0 Hari"
                        android:textColor="#1E255E"
                        android:textSize="22sp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <!-- SAKIT -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_summary"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/alpha"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Sakit"
                        android:textColor="#7A7A7A"
                        android:textSize="14sp"/>

                    <TextView
                        android:id="@+id/tvSakit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="0 Hari"
                        android:textColor="#1E255E"
                        android:textSize="22sp"
                        android:textStyle="bold"/>

                </LinearLayout>

            </GridLayout>

            <!-- TITLE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="Riwayat Absensi"
                android:textColor="#1E255E"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <!-- RECYCLER VIEW -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>

    </ScrollView>

    <!-- NAVBAR -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:itemIconTint="#4B5CFF"
        app:itemTextColor="#4B5CFF"
        app:menu="@menu/bottom_menu"/>

</LinearLayout>
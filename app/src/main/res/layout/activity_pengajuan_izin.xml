<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pengajuan Izin"
            android:textColor="#111827"
            android:textSize="28sp"
            android:textStyle="bold"/>

        <!-- SUBTITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Ajukan izin, sakit, atau cuti"
            android:textColor="#6B7280"
            android:textSize="14sp"/>

        <!-- CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_summary"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="22dp">

            <!-- JENIS -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jenis Pengajuan"
                android:textColor="#374151"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <Spinner
                android:id="@+id/spJenis"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_edittext"/>

            <!-- TANGGAL -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="Tanggal"
                android:textColor="#374151"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/etTanggal"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_edittext"
                android:clickable="true"
                android:focusable="false"
                android:hint="Pilih tanggal"
                android:padding="16dp"
                android:textColor="#111827"
                android:textColorHint="#9CA3AF"/>

            <!-- WAKTU -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="Waktu"
                android:textColor="#374151"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/etWaktu"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_edittext"
                android:clickable="true"
                android:focusable="false"
                android:hint="Pilih waktu"
                android:padding="16dp"
                android:textColor="#111827"
                android:textColorHint="#9CA3AF"/>

            <!-- KETERANGAN -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="Alasan / Keterangan"
                android:textColor="#374151"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/etKeterangan"
                android:layout_width="match_parent"
                android:layout_height="130dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_edittext"
                android:gravity="top"
                android:hint="Tulis alasan pengajuan izin"
                android:padding="16dp"
                android:textColor="#111827"
                android:textColorHint="#9CA3AF"/>

        </LinearLayout>

        <!-- BUTTON -->
        <LinearLayout
            android:id="@+id/btnKirim"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_button"
            android:clickable="true"
            android:elevation="3dp"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kirim Pengajuan"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>